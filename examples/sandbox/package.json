{
  "name": "deck.gl-healpix-sandbox",
  "private": true,
  "description": "Sandbox for deck.gl-healpix.",
  "version": "1.0.0",
  "author": {
    "name": "Daniel da Silva",
    "email": "daniel@develpmentseed.org",
    "url": "https://github.com/danielfdsilva"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/developmentseed/healpix-layers-deck.gl"
  },
  "scripts": {
    "dev": "npm run clean && NODE_ENV=development vite",
    "build": "npm run clean && NODE_ENV=production tsc -b && vite build",
    "stage": "npm run clean && NODE_ENV=staging tsc -b && vite build",
    "clean": "rm -rf dist node_modules/.vite",
    "lint": "npm run lint:scripts",
    "lint:scripts": "eslint app/",
    "ts-check": "npx tsc --noEmit --skipLibCheck"
  },
  "engines": {
    "node": "22.x"
  },
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "devDependencies": {
    "@types/babel__core": "^7",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@deck.gl/core": "^9.3.1",
    "@deck.gl/extensions": "^9.3.1",
    "@deck.gl/layers": "^9.3.1",
    "@deck.gl/mapbox": "^9.3.1",
    "@deck.gl/react": "^9.3.1",
    "@developmentseed/deck.gl-healpix": "*",
    "@emotion/react": "^11.14.0",
    "@types/d3": "^7.4.3",
    "d3": "^7.9.0",
    "maplibre-gl": "^5.24.0",
    "polished": "^4.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-map-gl": "^8.1.1",
    "react-router": "^7.14.2",
    "zarrita": "^0.6.2"
  },
  "alias": {
    "$components": "~/app/components",
    "$styles": "~/app/styles",
    "$utils": "~/app/utils",
    "$hooks": "~/app/hooks",
    "$pages": "~/app/pages",
    "$test": "~/test",
    "$shared": "~/../_shared"
  }
}
