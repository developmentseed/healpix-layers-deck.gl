{
  "name": "deck.gl-healpix-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "Monorepo for HEALPix deck.gl layers and related packages",
  "scripts": {
    "build": "lerna run build",
    "build:watch": "lerna run build:watch",
    "clean": "lerna run clean",
    "ts-check": "lerna run ts-check",
    "test": "lerna run test",
    "lint": "lerna run lint",
    "versionup": "lerna version --no-git-tag-version --no-push",
    "publish:from": "lerna publish from-package --no-private"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.3.0",
    "lerna": "^8.1.2",
    "prettier": "^3.8.1",
    "rollup": "^4.57.1",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
